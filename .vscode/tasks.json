{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "pnpm dev:frontend",
      "group": "build",
      "presentation": {
        "label": "Frontend",
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local"
        }
      }
    },
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "pnpm dev:backend",
      "group": "build",
      "presentation": {
        "label": "Backend",
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "AzMap backend",
          "endsPattern": "localhost"
        }
      }
    },
    {
      "label": "Dev: Start All",
      "dependsOn": ["Start Frontend", "Start Backend"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
