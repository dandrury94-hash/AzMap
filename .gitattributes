# Normalize all text files to LF on commit
* text=auto eol=lf

# Source files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf

# Binary files — never diff or convert
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.db     binary
*.sqlite binary
